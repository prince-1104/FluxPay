# Database & Cache
DATABASE_URL="postgresql://settl:settl@localhost:5432/settl?schema=public"
REDIS_URL="redis://localhost:6379"

# Server Configuration
PORT=4000
NODE_ENV="development"
CLIENT_URL="http://localhost:3000"

# JWT Secrets
JWT_ACCESS_SECRET="your_jwt_access_secret_change_me_in_production"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_change_me_in_production"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# Google Auth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cashfree Payments
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""
CASHFREE_ENV="sandbox"

# Cloudflare R2 / AWS S3 Uploads
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Firebase Push Notifications
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Google Vision OCR
GOOGLE_VISION_API_KEY=""

# Email Notifications (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Settl <noreply@settl.com>"
