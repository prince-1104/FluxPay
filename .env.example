# Database & Cache
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
REDIS_URL="redis://default:password@host:port"

# Server Configuration
PORT=4000
NODE_ENV="production"
CLIENT_URL="https://your-app.vercel.app"
ALLOWED_ORIGINS="https://your-app.vercel.app,https://www.yourdomain.com"

# Web (set in Vercel — listed here for reference)
NEXT_PUBLIC_API_URL="https://your-api.onrender.com/api/v1"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_MOBILE_APK_URL=""

# Mobile
EXPO_PUBLIC_API_URL="https://your-api.onrender.com/api/v1"

# JWT Secrets — generate strong random values for production
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# Google Auth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cashfree Payments
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""
CASHFREE_ENV="sandbox"

# Cloudflare R2 / AWS S3 Uploads
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Firebase Push Notifications
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Google Vision OCR
GOOGLE_VISION_API_KEY=""

# Email Notifications (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Settl <noreply@yourdomain.com>"
