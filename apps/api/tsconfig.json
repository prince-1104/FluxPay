{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@settl/types": ["../../packages/types/src"],
      "@settl/utils": ["../../packages/utils/src"],
      "@settl/database": ["../../packages/database/src"]
    }
  },
  "include": ["src/**/*"]
}
