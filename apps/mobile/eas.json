{
  "cli": {
    "version": ">= 13.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.11.0",
      "pnpm": "10.13.1"
    },
    "preview": {
      "distribution": "internal",
      "node": "22.11.0",
      "pnpm": "10.13.1",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:4000/api/v1"
      }
    },
    "production": {
      "node": "22.11.0",
      "pnpm": "10.13.1",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://your-api.example.com/api/v1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
