{
  "name": "settl-monorepo",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "version": "1.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "build:api": "turbo run build --filter=api",
    "lint": "turbo run lint",
    "eas-build-post-install": "pnpm --filter @settl/types build && pnpm --filter @settl/utils build"
  },
  "devDependencies": {
    "turbo": "^2.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ],
    "overrides": {
      "@types/react": "^18.3.3",
      "@types/react-dom": "^18.3.0"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
